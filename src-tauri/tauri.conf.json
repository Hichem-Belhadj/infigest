{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "infigest",
  "version": "0.3.2",
  "identifier": "com.hichem.infigest",
  "build": {
    "frontendDist": "../dist/infigest",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build:angular"
  },
  "app": {
    "windows": [
      {
        "title": "infigest",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
