{
  "name": "infigest",
  "version": "0.3.2",
  "scripts": {
    "ng": "ng",
    "tauri": "tauri",
    "ng:serve": "ng serve -o",
    "tauri:serve": "wait-on tcp:4200 && tauri dev",
    "dev": "npm-run-all -p ng:serve tauri:serve",
    "build:angular": "ng build --configuration production",
    "build": "tauri build",
    "start": "npm run dev",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.14",
    "@angular/cdk": "^19.2.18",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@ngx-translate/core": "^16.0.4",
    "@taiga-ui/core": "^4.39.2",
    "@taiga-ui/experimental": "^4.39.2",
    "@taiga-ui/kit": "^4.39.2",
    "@taiga-ui/layout": "^4.39.2",
    "rxjs": "~7.8.0",
    "taiga-ui": "^4.39.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.14",
    "@angular/cli": "^19.2.14",
    "@angular/compiler-cli": "^19.2.0",
    "@tauri-apps/cli": "^2.5.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.5.5",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.7.2",
    "wait-on": "^8.0.3"
  }
}
